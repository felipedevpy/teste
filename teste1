def obter_conexao():
    return mysql.connector.connect(**DB_CONFIG)

def criar_tabelas():
    conn = obter_conexao()
    cursor = conn.cursor()
    
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS equipamentos (
            id INT AUTO_INCREMENT PRIMARY KEY, 
            serial VARCHAR(255) UNIQUE
        )
    """)
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS pecas (
            id INT AUTO_INCREMENT PRIMARY KEY, 
            equipamento_id INT, 
            nome VARCHAR(255), 
            sn_peca VARCHAR(255), 
            slot VARCHAR(50),
            FOREIGN KEY(equipamento_id) REFERENCES equipamentos(id),
            UNIQUE(equipamento_id, sn_peca)
        )
    """)
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS estoque (
            id INT AUTO_INCREMENT PRIMARY KEY, 
            nome_peca VARCHAR(255) UNIQUE, 
            quantidade INT
        )
    """)
    conn.commit()
    conn.close()

def gerar_proximo_serial(nome_peca):
    conn = obter_conexao()
    cursor = conn.cursor()
    prefixo = nome_peca.upper().replace(" ", "_").replace("Ú", "U").replace("Ã", "A")
    
    cursor.execute("SELECT sn_peca FROM pecas WHERE nome = %s ORDER BY id DESC LIMIT 1", (nome_peca,))
    res = cursor.fetchone()
    conn.close()
    
    if res:
        ultimo_sn = res[0]
        try:
            ultimo_numero = int(ultimo_sn.split("-")[-1])
            proximo_numero = ultimo_numero + 1
        except (ValueError, IndexError):
            proximo_numero = 1
    else:
        proximo_numero = 1
        
    return f"{prefixo}-{proximo_numero:04d}"

def gerar_imagem_qrcode(conteudo_serial):
    caminho_arquivo = os.path.join(OS_QRCODE_DIR, f"{conteudo_serial}.png")
    qr = qrcode.QRCode(version=1, box_size=10, border=4)
    qr.add_data(conteudo_serial)
    qr.make(fit=True)
    img = qr.make_image(fill_color="black", back_color="white")
    img.save(caminho_arquivo)
    return caminho_arquivo

def enviar_email_alerta(nome_peca, quantidade):
    if not SENHA_REMETENTE or SENHA_REMETENTE == "sua_senha_aqui":
        return
    try:
        msg = MIMEMultipart()
        msg['From'] = EMAIL_REMETENTE
        msg['To'] = EMAIL_DESTINATARIO
        msg['Subject'] = f"Alerta de Estoque Crítico: {nome_peca}"
        corpo = f"Olá Pablo, faltam apenas {quantidade} unidades de {nome_peca} no estoque."
        msg.attach(MIMEText(corpo, 'plain', 'utf-8'))
        server = smtplib.SMTP(SMTP_SERVER, SMTP_PORT)
        server.starttls()
        server.login(EMAIL_REMETENTE, SENHA_REMETENTE)
        server.sendmail(EMAIL_REMETENTE, EMAIL_DESTINATARIO, msg.as_string())
        server.quit()
    except Exception as e:
        print(f"Falha ao enviar e-mail: {e}")

def verificar_e_disparar_alerta(nome_peca, quantidade):
    if quantidade <= 2:
        t = threading.Thread(target=enviar_email_alerta, args=(nome_peca, quantidade))
        t.daemon = True
        t.start()

def adicionar_estoque_db(nome, qtd):
    conn = obter_conexao()
    cursor = conn.cursor()
    cursor.execute("""
        INSERT INTO estoque (nome_peca, quantidade) VALUES (%s, %s)
        ON DUPLICATE KEY UPDATE quantidade = quantidade + VALUES(quantidade)
    """, (nome, qtd))
    
    cursor.execute("SELECT quantidade FROM estoque WHERE nome_peca = %s", (nome,))
    qtd_atual = cursor.fetchone()[0]
    conn.commit()
    conn.close()
    verificar_e_disparar_alerta(nome, qtd_atual)

def descontar_estoque(nome_peca):
    conn = obter_conexao()
    cursor = conn.cursor()
    cursor.execute("SELECT quantidade FROM estoque WHERE nome_peca = %s", (nome_peca,))
    res = cursor.fetchone()
    if res and res[0] > 0:
        nova_qtd = res[0] - 1
        cursor.execute("UPDATE estoque SET quantidade = %s WHERE nome_peca = %s", (nova_qtd, nome_peca))
        conn.commit()
        conn.close()
        verificar_e_disparar_alerta(nome_peca, nova_qtd)
        return True
    conn.close()
    return False

def salvar_no_banco(serial_principal, nome_peca, sn_peca, slot):
    conn = obter_conexao()
    cursor = conn.cursor()
    cursor.execute("INSERT IGNORE INTO equipamentos (serial) VALUES (%s)", (serial_principal,))
    cursor.execute("SELECT id FROM equipamentos WHERE serial = %s", (serial_principal,))
    equip_id = cursor.fetchone()[0]
    try:
        cursor.execute("""
            INSERT INTO pecas (equipamento_id, nome, sn_peca, slot) 
            VALUES (%s, %s, %s, %s)
        """, (equip_id, nome_peca, sn_peca, slot))
        conn.commit()
    except mysql.connector.IntegrityError:
        pass
    finally:
        conn.close()

def buscar_peca_db(sn_peca):
    conn = obter_conexao()
    cursor = conn.cursor()
    cursor.execute("""
        SELECT p.nome, e.serial, p.slot 
        FROM pecas p
        INNER JOIN equipamentos e ON e.id = p.equipamento_id
        WHERE p.sn_peca = %s
    """, (sn_peca,))
    res = cursor.fetchone()
    conn.close()
    return res

