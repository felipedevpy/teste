def criar_tabelas():
    conn = sqlite3.connect(NOME_BANCO)
    cursor = conn.cursor()
    cursor.execute("PRAGMA foreign_keys = ON")
    cursor.execute("CREATE TABLE IF NOT EXISTS equipamentos (id INTEGER PRIMARY KEY AUTOINCREMENT, serial TEXT UNIQUE)")
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS pecas (
            id INTEGER PRIMARY KEY AUTOINCREMENT, 
            equipamento_id INTEGER, 
            nome TEXT, 
            sn_peca TEXT, 
            slot TEXT,
            FOREIGN KEY(equipamento_id) REFERENCES equipamentos(id),
            UNIQUE(equipamento_id, sn_peca)
        )
    """)
    try:
        cursor.execute("ALTER TABLE pecas ADD COLUMN slot TEXT")
    except sqlite3.OperationalError:
        pass
    cursor.execute("CREATE TABLE IF NOT EXISTS estoque (id INTEGER PRIMARY KEY AUTOINCREMENT, nome_peca TEXT UNIQUE, quantidade INTEGER)")
    conn.commit()
    conn.close()

def enviar_email_alerta(nome_peca, quantidade):
    """Função executada em segundo plano (Thread) para evitar travamentos no Kivy"""
    if not SENHA_REMETENTE or SENHA_REMETENTE == "sua_senha_aqui":
        print("ERRO: Senha de e-mail padrão detectada ou em branco! Configure a senha real no código.")
        return

    try:
        msg = MIMEMultipart()
        msg['From'] = EMAIL_REMETENTE
        msg['To'] = EMAIL_DESTINATARIO
        msg['Subject'] = f"Alerta de Estoque Crítico: {nome_peca}"

        corpo = f"Olá Pablo, faltam apenas {quantidade} unidades de {nome_peca} no estoque."
        msg.attach(MIMEText(corpo, 'plain', 'utf-8'))

        server = smtplib.SMTP(SMTP_SERVER, SMTP_PORT)
        server.starttls()
        server.login(EMAIL_REMETENTE, SENHA_REMETENTE)
        server.sendmail(EMAIL_REMETENTE, EMAIL_DESTINATARIO, msg.as_string())
        server.quit()
        print(f"E-mail de alerta enviado com sucesso para {EMAIL_DESTINATARIO}!")
    except Exception as e:
        print(f"Falha ao enviar e-mail de alerta: {e}")

def verificar_e_disparar_alerta(nome_peca, quantidade):
    """Garante o disparo do e-mail se a quantidade for igual ou inferior a 2 unidades"""
    if quantidade <= 2:
        t = threading.Thread(target=enviar_email_alerta, args=(nome_peca, quantidade))
        t.daemon = True
        t.start()

def adicionar_estoque_db(nome, qtd):
    conn = sqlite3.connect(NOME_BANCO)
    cursor = conn.cursor()
    cursor.execute("""
        INSERT INTO estoque (nome_peca, quantidade) VALUES (?, ?)
        ON CONFLICT(nome_peca) DO UPDATE SET quantidade = quantidade + ?
    """, (nome, qtd, qtd))
    
    cursor.execute("SELECT quantidade FROM estoque WHERE nome_peca = ?", (nome,))
    qtd_atual = cursor.fetchone()[0]
    conn.commit()
    conn.close()
    
    verificar_e_disparar_alerta(nome, qtd_atual)

def descontar_estoque(nome_peca):
    conn = sqlite3.connect(NOME_BANCO)
    cursor = conn.cursor()
    cursor.execute("SELECT quantidade FROM estoque WHERE nome_peca = ?", (nome_peca,))
    res = cursor.fetchone()
    if res and res[0] > 0:
        nova_qtd = res[0] - 1
        cursor.execute("UPDATE estoque SET quantidade = ? WHERE nome_peca = ?", (nova_qtd, nome_peca))
        conn.commit()
        conn.close()
        
        verificar_e_disparar_alerta(nome_peca, nova_qtd)
        return True
    conn.close()
    return False

def salvar_no_banco(serial_principal, nome_peca, sn_peca, slot):
    conn = sqlite3.connect(NOME_BANCO)
    cursor = conn.cursor()
    cursor.execute("INSERT OR IGNORE INTO equipamentos (serial) VALUES (?)", (serial_principal,))
    cursor.execute("SELECT id FROM equipamentos WHERE serial = ?", (serial_principal,))
    equip_id = cursor.fetchone()[0]
    try:
        cursor.execute("""
            INSERT INTO pecas (equipamento_id, nome, sn_peca, slot) 
            VALUES (?, ?, ?, ?)
        """, (equip_id, nome_peca, sn_peca, slot))
        conn.commit()
    except sqlite3.IntegrityError:
        pass
    finally:
        conn.close()

def buscar_peca_db(sn_peca):
    conn = sqlite3.connect(NOME_BANCO)
    cursor = conn.cursor()
    cursor.execute("""
        SELECT p.nome, e.serial, p.slot 
        FROM pecas p
        INNER JOIN equipamentos e ON e.id = p.equipamento_id
        WHERE p.sn_peca = ?
    """, (sn_peca,))
    res = cursor.fetchone()
    conn.close()
    return res

