class TelaMenu(Screen):
    def iniciar(self):
        sn = self.ids.entrada_sn.text.strip()
        if sn:
            seq = self.manager.get_screen('sequencia')
            seq.serial_equip = sn
            seq.indice_passo = 0
            seq.pecas_registradas = []
            seq.lista_pecas = ["Bomba Vácuo", "Fonte", "Display 5", "Display 7pol", "Placa Mãe", "Motor", "Relé"]
            self.manager.current = 'sequencia'

class TelaEstoque(Screen):
    def adicionar(self):
        peca = self.ids.spinner_pecas.text
        qtd = self.ids.qtd_entrada.text
        if peca != "Selecione o Componente" and qtd:
            adicionar_estoque_db(peca, int(qtd))
            self.ids.qtd_entrada.text = ""

class TelaConsulta(Screen):
    def buscar(self):
        sn = self.ids.busca_sn.text.strip()
        if sn:
            res = buscar_peca_db(sn)
            if res:
                self.ids.resultado_busca.text = (
                    f"COMPONENTES: {res[0]}\n"
                    f"MÁQUINA DESTINO: {res[1]}\n"
                    f"SLOT INSTALADO: {res[2]}"
                )
            else:
                self.ids.resultado_busca.text = "S/N NÃO ENCONTRADO!"

class TelaSequencia(Screen):
    serial_equip = StringProperty("")
    lista_pecas = ListProperty([])
    pecas_registradas = ListProperty([])
    indice_passo = NumericProperty(0)
    peca_atual = StringProperty("")
    buffer_leitor = ""

    def on_enter(self):
        Window.bind(on_key_down=self._capturar_leitor)
        self.verificar_fim()

    def on_leave(self):
        Window.unbind(on_key_down=self._capturar_leitor)

    def verificar_fim(self):
        if self.indice_passo >= len(self.lista_pecas):
            final = self.manager.get_screen('finalizado')
            final.historico = self.pecas_registradas
            self.manager.current = 'finalizado'
        else:
            self.peca_atual = self.lista_pecas[self.indice_passo]
            self.ids.aviso_estoque.text = ""

    def _capturar_leitor(self, window, key, scancode, codepoint, modifiers):
        if key == 8: return False
        if key == 13:
            if self.buffer_leitor:
                if descontar_estoque(self.peca_atual):
                    self.ir_para_slot(self.buffer_leitor)
                else:
                    # IMPLEMENTAÇÃO DA OPÇÃO 1:
                    # Se falhar o desconto (estoque zerado), registra como pulado por falta e avança!
                    self.pecas_registradas.append(f"{self.peca_atual}: PULADO (SEM ESTOQUE)")
                    self.indice_passo += 1
                    self.verificar_fim()
                self.buffer_leitor = ""
            return True
        if codepoint:
            self.buffer_leitor += codepoint
            return True
        return False

    def ir_para_slot(self, sn_lido):
        tela_slot = self.manager.get_screen('slots')
        tela_slot.serial_equip = self.serial_equip
        tela_slot.peca_nome = self.peca_atual
        tela_slot.peca_sn = sn_lido
        self.manager.current = 'slots'

    def pular_peca(self):
        self.pecas_registradas.append(f"{self.peca_atual}: PULADO (MANUAL)")
        self.indice_passo += 1
        self.verificar_fim()

    def voltar_menu(self):
        self.manager.current = 'menu'

class TelaSlot(Screen):
    serial_equip = ""
    peca_nome = StringProperty("")
    peca_sn = ""

    def on_enter(self):
        self.ids.grid_slots.clear_widgets()
        for s in ['A','B','C']:
            for i in range(1, 5):
                btn = Button(
                    text=f"{s}{i}", 
                    size_hint=[None, None],
                    size=['100dp', '60dp'],
                    background_normal='',
                    background_color=[0, 0, 0, 0], 
                    color=[1, 1, 1, 1],
                    bold=True,
                    font_size='18sp'
                )
                
                with btn.canvas.before:
                    Color(rgba=[0.13, 0.49, 0.77, 1])
                    RoundedRectangle(size=btn.size, pos=btn.pos, radius=[8,])
                
                btn.bind(pos=self._update_canvas, size=self._update_canvas)
                btn.bind(on_press=self.salvar)
                self.ids.grid_slots.add_widget(btn)

    def _update_canvas(self, instance, value):
        instance.canvas.before.clear()
        with instance.canvas.before:
            color = [0.18, 0.59, 0.90, 1] if instance.state == 'down' else [0.13, 0.49, 0.77, 1]
            Color(rgba=color)
            RoundedRectangle(size=instance.size, pos=instance.pos, radius=[8,])

    def salvar(self, instancia):
        salvar_no_banco(self.serial_equip, self.peca_nome, self.peca_sn, instancia.text)
        seq = self.manager.get_screen('sequencia')
        seq.pecas_registradas.append(f"{self.peca_nome}: {self.peca_sn} (Slot {instancia.text})")
        seq.indice_passo += 1
        self.manager.current = 'sequencia'

class TelaFinalizado(Screen):
    historico = ListProperty([])
    def on_enter(self):
        self.ids.label_resumo.text = "RELATÓRIO FINAL:\n\n" + "\n".join(self.historico)
    def reiniciar(self):
        self.manager.current = 'menu'

class AppScanner(App):
    def build(self): 
        Window.clearcolor = [0.96, 0.96, 0.98, 1]
        criar_tabelas()
        sm = ScreenManager(transition=FadeTransition(duration=0.15))
        sm.add_widget(TelaMenu(name='menu'))
        sm.add_widget(TelaEstoque(name='estoque'))
        sm.add_widget(TelaConsulta(name='consulta'))
        sm.add_widget(TelaSequencia(name='sequencia'))
        sm.add_widget(TelaSlot(name='slots'))
        sm.add_widget(TelaFinalizado(name='finalizado'))
        return sm

if __name__ == '__main__':
    AppScanner().run()
